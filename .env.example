# Client-side Firebase config (public values)
NEXT_PUBLIC_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="YOUR_FIREBASE_AUTH_DOMAIN"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
# Obrigatorio para gravar audio (TTS ElevenLabs ou upload de teste): ative Storage no Console e use o nome exato do bucket.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="YOUR_FIREBASE_STORAGE_BUCKET"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="YOUR_FIREBASE_MESSAGING_SENDER_ID"
NEXT_PUBLIC_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"

# Firebase Admin (server-only). Use a service account from Firebase Console.
FIREBASE_ADMIN_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
FIREBASE_ADMIN_CLIENT_EMAIL="YOUR_FIREBASE_ADMIN_CLIENT_EMAIL"
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
# Mesmo valor que NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET (recomendado no servidor).
FIREBASE_ADMIN_STORAGE_BUCKET="YOUR_FIREBASE_STORAGE_BUCKET"
# Em Firebase App Hosting, nomes FIREBASE_* sao reservados — use estes (mesmos valores) em Environment/Secrets:
# SERVICE_ACCOUNT_PROJECT_ID / SERVICE_ACCOUNT_CLIENT_EMAIL / SERVICE_ACCOUNT_PRIVATE_KEY / SERVICE_ACCOUNT_STORAGE_BUCKET

# Opcional: HeyGen — se nao guardar personagem no Firestore, use ID e tipo aqui.
# HEYGEN_DEFAULT_CHARACTER_ID=""
# HEYGEN_DEFAULT_CHARACTER_KIND="avatar"

# Opcional: voice_id padrao no servidor se o usuario nao salvou elevenlabsVoiceId no Firestore (ex. plano pago).
# No plano gratuito da ElevenLabs, vozes de biblioteca costumam falhar na API — prefira Voice ID de "My Voices".
# ELEVENLABS_DEFAULT_VOICE_ID=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
